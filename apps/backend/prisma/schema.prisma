generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VIEWER
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  users     User[]
  template  Template?
  contracts Contract[]
  histories ContractHistory[]
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(VIEWER)
  isOwner      Boolean   @default(false)
  refreshToken String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  histories ContractHistory[]

  @@index([tenantId])
}

model Template {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  schema    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

enum ContractStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Contract {
  id               String         @id @default(uuid())
  tenantId         String
  status           ContractStatus @default(DRAFT)
  templateSnapshot Json
  payload          Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  histories ContractHistory[]

  @@index([tenantId])
}

model ContractHistory {
  id         String   @id @default(uuid())
  tenantId   String
  contractId String
  userId     String
  action     String
  field      String?
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([contractId])
}
